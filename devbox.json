{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "elmPackages.elm@latest",
    "nodejs@latest",
    "watchexec@latest"
  ],
  "shell": {
    "init_hook": [
      "npm install"
    ],
    "scripts": {
      "watch": "npm run watch",
      "test": "npm test",
      "gen": "npm run gen"
    }
  }
}
